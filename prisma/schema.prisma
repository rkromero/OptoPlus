// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  VENDEDOR
}

enum OrderStatus {
  PENDIENTE
  EN_PROCESO
  ENVIADO
  ENTREGADO
  CANCELADO
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  model       String
  color       String?
  brand       String?
  description String?
  imageUrl    String?
  priceList   Float
  priceCost   Float?
  stock       Int         @default(0)
  active      Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Client {
  id         String   @id @default(cuid())
  fullName   String
  dni        String?
  email      String?
  phone      String?
  address    String?
  city       String?
  province   String?
  notes      String?
  // Graduación ojo derecho
  odSphere   Float?
  odCylinder Float?
  odAxis     Int?
  // Graduación ojo izquierdo
  oiSphere   Float?
  oiCylinder Float?
  oiAxis     Int?
  orders     Order[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id          String      @id @default(cuid())
  orderNumber Int         @unique @default(autoincrement())
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id])
  status      OrderStatus @default(PENDIENTE)
  discount    Float?      @default(0)
  total       Float
  notes       String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
}

model CompanySettings {
  id      String  @id @default(cuid())
  name    String  @default("OptovisionPlus")
  address String?
  phone   String?
  email   String?
  logoUrl String?
}
